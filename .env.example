# Copy from PROYECTO_COMPLETO or link:
# cp "../Desktop/Sweet Little Trauma Produccion/PROYECTO_COMPLETO/.env" .env

# Optional: point to existing env file
# SLT_ENV_DIR=/path/to/PROYECTO_COMPLETO

# Private preview gate (frontend + API)
SLT_SITE_GATE_KEY=Dientito2032
VITE_SITE_GATE_KEY=Dientito2032

# Optional: override API base in Vite dev (defaults to http://127.0.0.1:3000)
# VITE_API_BASE=http://127.0.0.1:3000

# Production static dir (set automatically in render.yaml)
# SLT_STATIC_DIR=./dist
# Core production infrastructure - required before public launch
SLT_REQUIRE_PRODUCTION_INFRASTRUCTURE=false
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
AUTH_PROVIDER=supabase
AUTH_SECRET=
AUTH_JWT_SECRET=
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
SESSION_COOKIE_SECRET=
PUBLIC_APP_URL=
WEBHOOK_BASE_URL=
PUBLIC_WEBHOOK_BASE_URL=

# Storage / CDN
# local | r2 | s3 | supabase
STORAGE_PROVIDER=supabase
SLT_STORAGE_DIR=../storage/assets
STORAGE_BUCKET=slt-assets
STORAGE_PUBLIC_BASE_URL=
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_KEY=
STORAGE_SECRET_ACCESS_KEY=
MAX_UPLOAD_BYTES=26214400

# Runtime protections
API_RATE_LIMIT_PER_MINUTE=90
AUTH_RATE_LIMIT_PER_MINUTE=8
GENERATE_RATE_LIMIT_PER_MINUTE=10
BILLING_RATE_LIMIT_PER_MINUTE=20
MODERATION_DISABLED=false
OPENAI_MODERATION_ENABLED=false

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_CREATOR_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_FILM_LAB_MONTHLY=
STRIPE_PRICE_CREDITS_500=

# Provider keys
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
REPLICATE_API_TOKEN=
FAL_API_KEY=
RUNWAY_API_KEY=
ELEVENLABS_API_KEY=
STABILITY_API_KEY=
BYTEPLUS_VISION_AK=
BYTEPLUS_VISION_SK=
MINIMAX_API_KEY=
