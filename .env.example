# Copy from PROYECTO_COMPLETO or link:
# cp "../Desktop/Sweet Little Trauma Produccion/PROYECTO_COMPLETO/.env" .env

# Optional: point to existing env file
# SLT_ENV_DIR=/path/to/PROYECTO_COMPLETO

# Optional: override API base in Vite dev (defaults to http://127.0.0.1:3000)
# VITE_API_BASE=http://127.0.0.1:3000

# Production static dir (set automatically in render.yaml)
# SLT_STATIC_DIR=./dist
