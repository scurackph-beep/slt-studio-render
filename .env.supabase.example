# Copy to .env.supabase and fill with values from Supabase Dashboard → Project Settings
# Then run: npm run supabase:configure

# Settings → Database → Connection string → URI (Transaction pooler, port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# Optional (defaults shown)
AUTH_PROVIDER=supabase
STORAGE_PROVIDER=supabase
STORAGE_BUCKET=slt-assets
DATABASE_SSL=true
PUBLIC_APP_URL=http://127.0.0.1:5174
